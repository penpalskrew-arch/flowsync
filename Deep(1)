// Helper
function toast(msg, type=''){ const t=document.getElementById('toast'); t.textContent=msg; t.classList.add('show'); setTimeout(()=>t.classList.remove('show'),2200); }
function openMo(id){ document.getElementById(id).classList.add('open'); }
function closeMo(id){ document.getElementById(id).classList.remove('open'); }
function go(screenId){ document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active')); document.getElementById(screenId).classList.add('active'); if(screenId==='s-home') refreshPublicPreview(); if(screenId==='s-doctor') attachStaffView('doctor'); if(screenId==='s-reception') attachStaffView('reception'); if(screenId==='s-status') attachPatientListener(); }

// ========== SINGLE SOURCE OF TRUTH: LIVE QUEUE STATE (Firestore collection) ==========
// Queue documents: clinics/{cid}/queue/{patientId} with fields: token (number), name, type, status, position, createdAt, note, phone, visits
// CLINIC STATE: clinics/{cid} fields: doctorPin, receptionPin, name, paused, pauseMsg, delayMins, startTime, stopTime, theme, reviewLink

async function getNextToken(clinicId){ // atomic transaction
  const clinicRef = db.collection('clinics').doc(clinicId);
  const result = await db.runTransaction(async (transaction) => {
    const doc = await transaction.get(clinicRef);
    const current = doc.data()?.lastToken || 0;
    const next = current + 1;
    transaction.update(clinicRef, { lastToken: next });
    return next;
  });
  return result;
}

async function checkin(){
  const name = document.getElementById('pt-name').value.trim();
  if(!name) return toast('Enter your name');
  if(!checkinType) return toast('Select Online or Walk-in');
  if(!currentClinicId) return toast('Clinic not loaded');
  const btn = document.getElementById('ciBtn');
  btn.disabled = true; btn.textContent = 'Joining...';
  try{
    const tokenNum = await getNextToken(currentClinicId);
    const patientRef = db.collection('clinics').doc(currentClinicId).collection('queue').doc();
    const entry = {
      token: tokenNum,
      name: name,
      type: checkinType,
      status: 'waiting', // waiting, with-doctor, done, next
      createdAt: firebase.firestore.FieldValue.serverTimestamp(),
      phone: '',
      note: '',
      visits: 1,
      updatedAt: firebase.firestore.FieldValue.serverTimestamp()
    };
    await patientRef.set(entry);
    // store session locally
    localStorage.setItem(`fs_${currentClinicId}`, JSON.stringify({ docId: patientRef.id, token: tokenNum, name, type: checkinType }));
    myTokenObj = { token: tokenNum, docId: patientRef.id, name, type: checkinType, status: 'waiting' };
    toast(`Token #${tokenNum} assigned!`, 'g');
    go('s-status');
    document.getElementById('stName').innerHTML = name;
    document.getElementById('stToken').innerHTML = `#${tokenNum}`;
  } catch(e){ toast('Check-in failed', 'r'); }
  finally{ btn.disabled=false; btn.textContent='Check in →'; }
}

async function roomReady(){
  if(!currentClinicId) return;
  const queueCol = db.collection('clinics').doc(currentClinicId).collection('queue');
  // transaction: get current with-doctor, mark as done, then pick next (ordered by token asc, status waiting/next)
  await db.runTransaction(async (transaction) => {
    const snapshot = await transaction.get(queueCol.where('status', 'in', ['with-doctor', 'next', 'waiting']).limit(20));
    const docs = snapshot.docs.map(d => ({ id: d.id, ...d.data() }));
    const currentDoctor = docs.find(d => d.status === 'with-doctor');
    if(currentDoctor){
      transaction.update(queueCol.doc(currentDoctor.id), { status: 'done', completedAt: firebase.firestore.FieldValue.serverTimestamp() });
    }
    const waitingDocs = docs.filter(d => d.status !== 'with-doctor' && d.status !== 'done').sort((a,b)=> a.token - b.token);
    // 2:1 ordering: online,online,walkin (simplified)
    const ordered = waitingDocs.sort((a,b)=>{
      if(a.type === b.type) return a.token - b.token;
      if(a.type === 'online' && b.type === 'walkin') return -1;
      return 1;
    });
    const next = ordered[0];
    if(next) transaction.update(queueCol.doc(next.id), { status: 'with-doctor', calledAt: firebase.firestore.FieldValue.serverTimestamp() });
  });
  toast('Queue updated');
}

async function noShow(){
  if(!selectedPatientDocId || !currentClinicId) return;
  const queueRef = db.collection('clinics').doc(currentClinicId).collection('queue').doc(selectedPatientDocId);
  await queueRef.update({ status: 'skipped', skippedAt: firebase.firestore.FieldValue.serverTimestamp() });
  toast('Patient skipped, moved to next available', 'a');
  closeMo('pm');
  selectedPatientDocId = null;
}

async function addDelay(minutes){
  if(!currentClinicId) return;
  const clinicRef = db.collection('clinics').doc(currentClinicId);
  await clinicRef.update({ delayMins: firebase.firestore.FieldValue.increment(minutes) });
  toast(`+${minutes} min delay`);
}

async function doPause(){
  const msg = document.getElementById('pau-msg').value || 'Queue paused';
  await db.collection('clinics').doc(currentClinicId).update({ paused: true, pauseMsg: msg });
  closeMo('paum');
}
async function resumeQ(){
  await db.collection('clinics').doc(currentClinicId).update({ paused: false, pauseMsg: '', delayMins: 0 });
}

async function clearQ(){
  if(!confirm('Clear entire queue?')) return;
  const snap = await db.collection('clinics').doc(currentClinicId).collection('queue').get();
  const batch = db.batch();
  snap.forEach(doc => batch.delete(doc.ref));
  await batch.commit();
  await db.collection('clinics').doc(currentClinicId).update({ lastToken: 0, delayMins: 0 });
  toast('Queue cleared');
}

async function addManual(){
  const name = document.getElementById('add-name').value.trim();
  if(!name) return;
  const tokenNum = await getNextToken(currentClinicId);
  const patientRef = db.collection('clinics').doc(currentClinicId).collection('queue').doc();
  await patientRef.set({ name, token: tokenNum, type: 'walkin', status: 'waiting', createdAt: firebase.firestore.FieldValue.serverTimestamp(), addedByStaff: true });
  document.getElementById('add-name').value = '';
  closeMo('apm');
  toast(`${name} added (#${tokenNum})`);
}

// ========== REAL-TIME LISTENERS (SINGLE SOURCE OF TRUTH) ==========
function attachPublicPreview(){
  if(!currentClinicId) return;
  const q = db.collection('clinics').doc(currentClinicId).collection('queue').where('status', 'in', ['waiting', 'next', 'with-doctor', 'skipped']);
  return q.onSnapshot(snap => {
    let online=0, walkin=0;
    snap.forEach(d => { const st = d.data().status; if(st !== 'done') { if(d.data().type === 'online') online++; else walkin++; } });
    document.getElementById('pre-on').innerText = online;
    document.getElementById('pre-wk').innerText = walkin;
  });
}

function attachStaffView(role){
  if(activeUnsubscribes.queue) activeUnsubscribes.queue();
  const q = db.collection('clinics').doc(currentClinicId).collection('queue').orderBy('token', 'asc');
  activeUnsubscribes.queue = q.onSnapshot(snap => {
    const all = snap.docs.map(d => ({ id: d.id, ...d.data() }));
    const active = all.filter(p => p.status !== 'done');
    const current = active.find(p => p.status === 'with-doctor');
    const waiting = active.filter(p => p.status === 'waiting' || p.status === 'next' || p.status === 'skipped');
    const ordered = waiting.sort((a,b)=> a.token - b.token);
    if(role === 'doctor' && document.getElementById('s-doctor').classList.contains('active')){
      document.getElementById('docCurName').innerHTML = current ? current.name : '—';
      document.getElementById('docCurMeta').innerHTML = current ? `Token #${current.token} · ${current.type}` : 'No active patient';
      const noteField = document.getElementById('docNote');
      if(current && (!noteField._curToken || noteField._curToken !== current.token)){
        noteField.value = current.note || '';
        noteField._curToken = current.token;
      }
      const html = ordered.map(p => `<div class="qi" onclick="selectPatientForNoShow('${p.id}','${p.name}')"><div class="qn">${p.token}</div><div><strong>${p.name}</strong><div style="font-size:12px">${p.type}</div></div></div>`).join('');
      document.getElementById('docQueueList').innerHTML = html || '<div class="empty">Queue empty</div>';
    }
    if(role === 'reception' && document.getElementById('s-reception').classList.contains('active')){
      let onC=0, wkC=0;
      active.forEach(p => { if(p.type==='online') onC++; else wkC++; });
      document.getElementById('recOn').innerText = onC;
      document.getElementById('recWk').innerText = wkC;
      const html = active.map(p => `<div class="qi" onclick="selectPatientForNoShow('${p.id}','${p.name}')"><div class="qn">${p.token}</div><div><strong>${p.name}</strong><div style="font-size:12px">${p.type} · ${p.status}</div></div></div>`).join('');
      document.getElementById('recQueueList').innerHTML = html || '<div>None</div>';
    }
  });
  // clinic status listener for pause/delay
  if(activeUnsubscribes.clinic) activeUnsubscribes.clinic();
  activeUnsubscribes.clinic = db.collection('clinics').doc(currentClinicId).onSnapshot(doc => {
    if(doc.exists){
      currentClinicData = doc.data();
      const paused = currentClinicData?.paused;
      const msg = currentClinicData?.pauseMsg;
      ['docPause','recPause'].forEach(id => {
        const el = document.getElementById(id);
        if(el) {
          if(paused){ el.style.display='block'; el.innerText = `⏸ ${msg || 'Paused'}`; }
          else el.style.display='none';
        }
      });
    }
  });
}

function attachPatientListener(){
  if(!myTokenObj?.docId || !currentClinicId) return;
  if(activeUnsubscribes.patient) activeUnsubscribes.patient();
  const patientRef = db.collection('clinics').doc(currentClinicId).collection('queue').doc(myTokenObj.docId);
  activeUnsubscribes.patient = patientRef.onSnapshot(doc => {
    if(!doc.exists) return;
    const data = doc.data();
    myTokenObj.status = data.status;
    const allQueue = db.collection('clinics').doc(currentClinicId).collection('queue').where('status', 'in', ['waiting','next','with-doctor','skipped']);
    allQueue.get().then(snap => {
      let all = []; snap.forEach(d => all.push({...d.data(), id:d.id}));
      const waitingSorted = all.filter(p => p.status === 'waiting' || p.status === 'next').sort((a,b)=> a.token - b.token);
      let pos = waitingSorted.findIndex(p => p.token === data.token);
      if(data.status === 'with-doctor'){
        document.getElementById('stPos').innerHTML = '→';
        document.getElementById('stMsg').innerHTML = "It's your turn — please go in";
        document.getElementById('stNowBan').style.display = 'block';
        document.getElementById('stNextBan').style.display = 'none';
      } else if(data.status === 'done'){
        document.getElementById('stPos').innerHTML = '✓';
        document.getElementById('stMsg').innerHTML = 'Visit completed. Thank you!';
        localStorage.removeItem(`fs_${currentClinicId}`);
        if(currentClinicData?.reviewLink) document.getElementById('reviewBtn').style.display='block';
        document.getElementById('stNowBan').style.display='none';
        document.getElementById('stNextBan').style.display='none';
      } else if(data.status === 'next' || (pos === 0 && data.status ==='waiting')){
        document.getElementById('stPos').innerHTML = '1';
        document.getElementById('stMsg').innerHTML = "You're next! Please be ready.";
        document.getElementById('stNextBan').style.display = 'block';
        document.getElementById('stNowBan').style.display = 'none';
      } else {
        const ahead = pos + 1;
        document.getElementById('stPos').innerHTML = ahead;
        document.getElementById('stMsg').innerHTML = `${ahead} ${ahead===1?'person':'people'} ahead`;
        document.getElementById('stNextBan').style.display = 'none';
        document.getElementById('stNowBan').style.display = 'none';
      }
      document.getElementById('stToken').innerHTML = `#${data.token}`;
    });
  });
}

