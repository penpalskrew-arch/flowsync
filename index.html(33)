// ==================== CHECK-IN ====================
async function checkin() {
  if (!CID) { toast("No clinic selected", "r"); return; }
  if (!isOpen()) { toast("Queue not open right now", "r"); return; }
  const name = document.getElementById("pt-name").value.trim();
  const ph = document.getElementById("pt-ph").value.trim();
  const cleanPh = ph.replace(/\D/g, "");
  if (!name) { toast("Please enter your name"); return; }
  if (!ciType) { toast("Select Online or Walk-in"); return; }

  const btn = document.getElementById("ci-btn");
  btn.disabled = true; btn.textContent = "Checking in...";
  try {
    // Check for existing active token
    const qs = await _db.ref(`queues/${CID}`).once("value");
    if (qs.exists()) {
      let active = null;
      qs.forEach(c => {
        const p = c.val();
        const pCl = (p.ph || "").replace(/\D/g, "");
        if (cleanPh && pCl && pCl === cleanPh && p.status !== "done") active = p;
      });
      if (active) {
        toast(`You already have token #${active.token}`, "a");
        myTok = active.token; myType = active.type || "online";
        localStorage.setItem(`myToken_${CID}`, active.token);
        document.getElementById("st-name").textContent = active.name;
        document.getElementById("st-tok").textContent = `#${active.token}`;
        document.getElementById("st-tok").className = `tok-big ${active.type === "walkin" ? "tok-wk" : "tok-on"}`;
        document.getElementById("st-tok-type").innerHTML = `<span class="${active.type === "walkin" ? "tag-wk" : "tag-on"}">${active.type === "walkin" ? "🚶 Walk-in" : "🌐 Online"}</span>`;
        go("s-status"); return;
      }
    }

    // Gift code
    const gc = document.getElementById("gift-in")?.value.trim().toUpperCase() || "";
    if (gc) {
      const gs = await _db.ref(`gifts/${CID}/${gc}`).once("value");
      if (!gs.exists()) { toast("Invalid gift code", "r"); return; }
      if (gs.val().used) { toast("Gift code already used", "r"); return; }
      await _db.ref(`gifts/${CID}/${gc}`).update({ used: true, usedBy: name, usedAt: Date.now() });
    }

    // Max patients check
    if (cdata?.maxPatients && cdata.maxPatients > 0) {
      const fq = await _db.ref(`queues/${CID}`).once("value");
      const cnt = fq.exists() ? getActive(fq).length : 0;
      if (cnt >= cdata.maxPatients) { toast("Queue is full for today", "r"); return; }
    }

    // Visit counter
    let visits = 1;
    if (cleanPh) {
      const ps = await _db.ref(`patients/${CID}/${cleanPh}`).once("value");
      if (ps.exists()) { visits = (ps.val().visits || 1) + 1; await _db.ref(`patients/${CID}/${cleanPh}`).update({ visits, name, lastVisit: Date.now() }); }
      else await _db.ref(`patients/${CID}/${cleanPh}`).set({ visits: 1, name, ph, firstVisit: Date.now(), lastVisit: Date.now() });
    }

    // Atomic token
    let token;
    await _db.ref(`counters/${CID}`).transaction(cur => { token = (cur || 0) + 1; return token; });

    // Determine initial status
    const fq = await _db.ref(`queues/${CID}`).once("value");
    const activeQ = fq.exists() ? getActive(fq) : [];
    const hasDr = activeQ.some(p => p.status === "with-doctor");
    const hasOthers = activeQ.some(p => p.status === "waiting" || p.status === "next");
    const initialStatus = (!hasDr && !hasOthers) ? "next" : "waiting";
    const nowStr = new Date().toLocaleTimeString("en-IN", { hour: "2-digit", minute: "2-digit" });

    await _db.ref(`queues/${CID}`).push({
      name, token, type: ciType, hasPhone: !!cleanPh,
      status: initialStatus, time: nowStr, visits,
      ph: ph || "", isGift: !!gc, note: "", at: Date.now()
    });

    localStorage.setItem(`myToken_${CID}`, token);
    myTok = token; myPh = ph; myType = ciType; myVisits = visits;
    document.getElementById("st-name").textContent = name;
    document.getElementById("st-tok").textContent = `#${token}`;
    document.getElementById("st-tok").className = `tok-big ${ciType === "walkin" ? "tok-wk" : "tok-on"}`;
    document.getElementById("st-tok-type").innerHTML = `<span class="${ciType === "walkin" ? "tag-wk" : "tag-on"}">${ciType === "walkin" ? "🚶 Walk-in" : "🌐 Online"}</span>`;
    if (cdata?.reviewLink) document.getElementById("st-review").style.display = "block";
    if (cdata?.gifts) document.getElementById("gift-row").style.display = "block";
    go("s-status");
    if (gc) toast("🎁 Gift redeemed!", "g");
    else if (visits === 1) toast("Welcome! First visit 😊", "g");
    else if (visits >= 4 && visits % 4 === 0) toast("🎉 Free gift unlocked for a friend!", "a");
    else toast(`Welcome back! Visit #${visits}`);
    if (cdata?.loyaltyEnabled) renderStamps(visits, ph);
  } catch (e) { toast("Error: " + e.message, "r"); }
  finally { btn.disabled = false; btn.textContent = "Check in →"; }
}

// ==================== PATIENT STATUS (LIVE SYNC) ====================
function setupStatus() {
  if (!CID || !myTok) return;
  if (uQ) { uQ(); uQ = null; }
  uQ = _db.ref(`queues/${CID}`).on("value", snap => {
    if (!snap || !snap.exists()) return;
    updateStatus(snap);
    const ann = cdata?.globalAnnouncement;
    const el = document.getElementById("st-announce");
    if (el) { el.textContent = ann || ""; el.style.display = ann ? "block" : "none"; }
    const d = cdata?.delay || 0;
    const db2 = document.getElementById("st-delay");
    if (db2) { db2.textContent = d > 0 ? `⏰ Clinic running ${d} min behind` : ""; db2.style.display = d > 0 ? "block" : "none"; }
  });
}

function updateStatus(snap) {
  if (!myTok || !snap) return;
  const all = []; snap.forEach(c => all.push({ ...c.val(), _k: c.key }));
  const mine = all.find(p => Number(p.token) === Number(myTok));
  if (!mine) return;
  const waiting = all.filter(p => p.status === "waiting" || p.status === "skipped" || p.status === "next");
  const exec = execOrder(waiting);
  const myPos = exec.findIndex(p => Number(p.token) === Number(myTok));
  const ring = document.getElementById("st-ring");

  if (prevSt && prevSt !== mine.status && (mine.status === "next" || mine.status === "with-doctor")) ding();
  prevSt = mine.status;

  document.getElementById("st-skip").style.display = mine.wasSkipped ? "block" : "none";

  if (mine.status === "with-doctor") {
    document.getElementById("st-num").textContent = "→";
    document.getElementById("st-title").textContent = "It's your turn!";
    document.getElementById("st-sub").textContent = "Please go in now";
    document.getElementById("st-now").style.display = "block";
    document.getElementById("st-next").style.display = "none";
    ring.style.borderColor = "var(--on)";
    if (mine.note) { document.getElementById("st-note").style.display = "block"; document.getElementById("st-note-txt").textContent = mine.note; }
  } else if (mine.status === "done" || mine.status === "recently-done") {
    document.getElementById("st-num").textContent = "✓";
    document.getElementById("st-title").textContent = "Visit complete";
    document.getElementById("st-sub").textContent = "Thank you for visiting today";
    document.getElementById("st-now").style.display = "none";
    document.getElementById("st-next").style.display = "none";
    ring.style.borderColor = "var(--on)";
    if (mine.note) { document.getElementById("st-note").style.display = "block"; document.getElementById("st-note-txt").textContent = mine.note; }
    if (cdata?.reviewLink) document.getElementById("st-review").style.display = "block";
    localStorage.removeItem(`myToken_${CID}`);
  } else if (mine.status === "next") {
    document.getElementById("st-num").textContent = "1";
    document.getElementById("st-title").textContent = "You're next!";
    document.getElementById("st-sub").textContent = "Please make your way over";
    document.getElementById("st-next").style.display = "block";
    document.getElementById("st-now").style.display = "none";
    ring.style.borderColor = "var(--wk)";
  } else {
    const pos = myPos >= 0 ? myPos + 1 : "-";
    document.getElementById("st-num").textContent = pos;
    document.getElementById("st-title").textContent = `Token #${myTok} · ` + (myPos === 0 ? "Almost your turn." : `${myPos} patient${myPos === 1 ? "" : "s"} ahead`);
    document.getElementById("st-sub").textContent = "We will alert you when it is nearly your turn";
    document.getElementById("st-next").style.display = "none";
    document.getElementById("st-now").style.display = "none";
    ring.style.borderColor = "var(--gl)";
  }
}

