// ==================== CLEAR QUEUE ====================
async function clearQ() {
  if (!confirm("Clear entire queue? Cannot be undone.")) return;
  try {
    await _db.ref(`queues/${CID}`).remove();
    await _db.ref(`counters/${CID}`).remove();
    await _db.ref(`clinics/${CID}`).update({ delay: 0, paused: false, globalAnnouncement: "" });
    toast("Queue cleared", "g");
  } catch (e) { toast("Error", "r"); }
}

// ==================== SETTINGS ====================
function openSettings() {
  if (!cdata) return;
  document.getElementById("set-start").value = cdata.startTime || "";
  document.getElementById("set-stop").value = cdata.stopTime || "";
  document.getElementById("set-max").value = cdata.maxPatients || 0;
  document.getElementById("set-grace").value = cdata.gracePeriod || 5;
  setLoy = cdata.loyaltyEnabled || false;
  document.getElementById("set-loy-tog").classList.toggle("on", setLoy);
  document.getElementById("set-loy-row").style.display = setLoy ? "block" : "none";
  document.getElementById("set-reward").value = cdata.rewardDesc || "";
  openMo("setm");
}

function toggleSetLoy() {
  setLoy = !setLoy;
  document.getElementById("set-loy-tog").classList.toggle("on", setLoy);
  document.getElementById("set-loy-row").style.display = setLoy ? "block" : "none";
}

async function saveSettings() {
  const start = document.getElementById("set-start").value;
  const stop = document.getElementById("set-stop").value;
  const max = parseInt(document.getElementById("set-max").value) || 0;
  const grace = parseInt(document.getElementById("set-grace").value) || 5;
  const reward = document.getElementById("set-reward").value.trim();
  try {
    await _db.ref(`clinics/${CID}`).update({ startTime: start, stopTime: stop, maxPatients: max, gracePeriod: grace, loyaltyEnabled: setLoy, rewardDesc: setLoy ? reward : "" });
    closeMo("setm"); toast("Settings saved", "g");
  } catch (e) { toast("Error: " + e.message, "r"); }
}

// ==================== LOYALTY ====================
function renderStamps(visits, ph) {
  document.getElementById("st-stamps").style.display = "block";
  const cycle = ((visits - 1) % 4) + 1;
  document.getElementById("st-slbl").textContent = `${cycle}/4`;
  const rd = cdata?.rewardDesc || "free consultation";
  document.getElementById("st-sdesc").textContent = `Every 4 visits earns: ${rd} for a friend or family member`;
  let dots = "";
  for (let i = 1; i <= 4; i++) dots += `<div class="sd ${i <= cycle ? "on" : ""}">${i <= cycle ? "✓" : "○"}</div>`;
  document.getElementById("st-sdots").innerHTML = dots;
  if (cycle === 4 && visits >= 4) {
    const code = giftCode(ph || myTok, visits);
    document.getElementById("st-gcode").textContent = code;
    document.getElementById("st-rdesc").textContent = rd;
    document.getElementById("st-reward").style.display = "block";
    _db.ref(`gifts/${CID}/${code}`).set({ issuedTo: ph || "", issuedAt: Date.now(), used: false, visits });
    _db.ref(`clinics/${CID}/gifts`).set(true);
  }
}

function shareGift() {
  const code = document.getElementById("st-gcode").textContent;
  const cn = cdata?.name || "the clinic";
