// Queue helpers
function getActive(snap) {
  const q = [];
  snap.forEach(c => {
    const p = c.val();
    if (p.status !== "done" && p.type !== "visitor") q.push({ ...p, _k: c.key });
  });
  return q.sort((a, b) => Number(a.token) - Number(b.token));
}

function getVisitors(snap) {
  const v = [];
  snap.forEach(c => { const p = c.val(); if (p.type === "visitor") v.push({ ...p, _k: c.key }); });
  return v;
}

function execOrder(waiting) {
  const on = waiting.filter(p => p.type === "online");
  const wk = waiting.filter(p => p.type === "walkin");
  const out = [];
  let oi = 0, wi = 0, slot = 0;
  while (oi < on.length || wi < wk.length) {
    if (slot % 3 === 2) {
      if (wi < wk.length) out.push(wk[wi++]);
      else if (oi < on.length) out.push(on[oi++]);
    } else {
      if (oi < on.length) out.push(on[oi++]);
      else if (wi < wk.length) out.push(wk[wi++]);
    }
    slot++;
  }
  return out;
}

function isOpen() {
  if (!cdata) return true;
  if (cdata.paused) return false;
  const now = new Date();
  const hm = `${String(now.getHours()).padStart(2, "0")}:${String(now.getMinutes()).padStart(2, "0")}`;
  if (cdata.startTime && hm < cdata.startTime) return false;
  if (cdata.stopTime && hm > cdata.stopTime) return false;
  return true;
}

function minsUntilOpen() {
  if (!cdata?.startTime) return null;
  const now = new Date();
  const [h, m] = cdata.startTime.split(":").map(Number);
  const open = new Date(now); open.setHours(h, m, 0, 0);
  if (open <= now) return null;
  return Math.round((open - now) / 60000);
}

function lbadge(v, sm) {
  if (!v) return "";
  const s = sm ? ' style="font-size:10px;margin-left:4px"' : "";
  if (v === 1) return `<span class="bdg bnew"${s}>New</span>`;
  if (v >= 4 && v % 4 === 0) return `<span class="bdg bfr"${s}>🎁 Free</span>`;
  return "";
}

function giftCode(ph, v) {
  const s = String(ph || "") + String(v || "");
  let h = 5381;
  for (let i = 0; i < s.length; i++) h = ((h << 5) + h) + s.charCodeAt(i);
  return "GIFT" + Math.abs(h).toString(36).toUpperCase().slice(0, 6);
}

