<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="theme-color" content="#F0F6FF"/>
<title>FlowSync · Clinic Queue System</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-database-compat.js"></script>
<style>
:root{
  --g:#1A73E8;--gd:#1557B0;--gl:rgba(26,115,232,0.10);--gm:rgba(26,115,232,0.25);
  --on:#00897B;--wk:#F57C00;--wkl:rgba(245,124,0,0.10);--wkm:rgba(245,124,0,0.28);
  --rd:#D32F2F;--rl:rgba(211,47,47,0.10);--rm:rgba(211,47,47,0.25);
  --bl:rgba(26,115,232,0.10);--bm:rgba(26,115,232,0.25);--bc:#1A73E8;
  --bg:#F0F6FF;--bg2:#FFFFFF;--bg3:#F4F7FB;--bg4:#E8EFF8;
  --s:#FFFFFF;--s2:#F0F4FA;--s3:#E2EAF4;
  --b:rgba(26,115,232,0.12);--brd:rgba(26,115,232,0.30);
  --t:#1A2340;--t2:#5A6A85;--t3:#9AAABF;
  --r:14px;--rs:10px;
  --gold:#F59E0B;--goldl:rgba(245,158,11,0.10);--goldm:rgba(245,158,11,0.28);
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;font-family:'Outfit',sans-serif;background:var(--bg);color:var(--t)}
.screen{display:none;min-height:100vh;flex-direction:column}.screen.active{display:flex}

#loader{position:fixed;inset:0;background:var(--bg);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:9999;gap:18px}
.lo-ring{width:62px;height:62px;border-radius:18px;background:var(--gl);border:1px solid var(--gm);display:flex;align-items:center;justify-content:center;font-size:28px;animation:glow 2s infinite}
@keyframes glow{0%,100%{box-shadow:0 0 0 0 var(--gm)}50%{box-shadow:0 0 0 14px rgba(0,200,150,0)}}
.spin{width:22px;height:22px;border:2px solid var(--b);border-top-color:var(--g);border-radius:50%;animation:spin .8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}

.tb{padding:14px 16px 12px;background:var(--bg2);border-bottom:1px solid var(--b);display:flex;align-items:center;gap:12px;position:sticky;top:0;z-index:10}
.bk{width:32px;height:32px;border-radius:50%;background:var(--s);border:1px solid var(--b);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:16px;color:var(--t2);flex-shrink:0}
.tbt{font-size:15px;font-weight:600}.tbs{font-size:11px;color:var(--t3);margin-top:1px}
.ldot{width:6px;height:6px;border-radius:50%;background:var(--g);display:inline-block;margin-right:5px;animation:blink 2s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}
.cnt{flex:1;padding:16px;overflow-y:auto}

.hero{background:var(--bg2);border-bottom:1px solid var(--b);padding:36px 20px 28px;text-align:center;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;top:-60px;left:50%;transform:translateX(-50%);width:240px;height:240px;background:radial-gradient(circle,rgba(0,200,150,.12) 0%,transparent 70%);pointer-events:none}
.logo{width:60px;height:60px;border-radius:18px;background:var(--gl);border:1px solid var(--gm);display:flex;align-items:center;justify-content:center;margin:0 auto 14px;font-size:28px}
.app-name{font-size:24px;font-weight:600;letter-spacing:-.5px}
.app-tag{font-size:12px;color:var(--t3);margin-top:6px;font-weight:300}
.clinic-tag{font-size:14px;font-weight:500;color:var(--g);margin-top:8px}

.lp{background:var(--s);border:1px solid var(--b);border-radius:var(--r);margin:16px 16px 0;overflow:hidden}
.lp-head{padding:14px 16px 10px;display:flex;align-items:center;justify-content:space-between}
.lp-title{font-size:13px;font-weight:600}
.lp-live{font-size:11px;color:var(--g);display:flex;align-items:center;gap:4px}
.lp-now{background:var(--bg3);margin:0 12px 12px;border-radius:var(--rs);padding:12px 14px;display:flex;align-items:center;gap:12px}
.lp-tok{font-size:22px;font-weight:600;font-family:'JetBrains Mono',monospace}
.lp-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:0 12px 12px}
.lp-stat{background:var(--bg3);border-radius:var(--rs);padding:10px 12px;text-align:center}
.lp-sv{font-size:22px;font-weight:600;font-family:'JetBrains Mono',monospace}
.lp-sl{font-size:11px;color:var(--t3);margin-top:2px}
.lp-msg{margin:0 12px 12px;padding:12px 14px;border-radius:var(--rs);font-size:13px;font-weight:500;text-align:center}
.lp-closed{background:var(--rl);border:1px solid var(--rm);color:#FF8090}
.lp-paused{background:var(--wkl);border:1px solid var(--wkm);color:var(--wk)}
.lp-opens{background:var(--gl);border:1px solid var(--gm);color:var(--g)}

.plist{display:flex;flex-direction:column;gap:10px;padding:16px}
.phint{font-size:11px;color:var(--t3);text-transform:uppercase;letter-spacing:.8px;margin-bottom:2px}
.pc{background:var(--s);border:1px solid var(--b);border-radius:var(--r);padding:16px;cursor:pointer;display:flex;align-items:center;gap:14px;transition:border-color .15s}
.pc:active{border-color:var(--brd)}
.pi{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0}
.pid{background:rgba(0,150,255,.12);border:1px solid rgba(0,150,255,.2)}
.pip{background:var(--gl);border:1px solid var(--gm)}
.pir{background:var(--wkl);border:1px solid var(--wkm)}
.pia{background:rgba(255,255,255,.05);border:1px solid var(--b)}
.pl{font-size:14px;font-weight:600}.pd{font-size:12px;color:var(--t3);margin-top:2px}
.pa{font-size:18px;color:var(--t3);margin-left:auto}

.pin-wrap{padding:24px 16px;flex:1}
.pin-card{background:var(--s);border:1px solid var(--b);border-radius:var(--r);padding:28px 20px}
.pin-h{font-size:18px;font-weight:600;margin-bottom:4px}
.pin-s{font-size:13px;color:var(--t3);margin-bottom:28px}
.pin-dots{display:flex;justify-content:center;gap:16px;margin-bottom:28px}
.pd0{width:14px;height:14px;border-radius:50%;background:var(--s2);border:1px solid var(--brd);transition:all .15s}
.pd0.on{background:var(--g);border-color:var(--g);box-shadow:0 0 8px var(--gm)}
.pgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.pk{padding:18px 8px;background:var(--bg3);border:1px solid var(--b);border-radius:var(--rs);font-size:22px;font-weight:500;cursor:pointer;text-align:center;font-family:'JetBrains Mono',monospace;color:var(--t);transition:all .1s}
.pk:active{background:var(--gl);border-color:var(--gm);color:var(--g)}
.pdel{font-size:14px;color:var(--t2);font-family:'Outfit',sans-serif}
.pin-err{font-size:13px;color:var(--rd);text-align:center;margin-top:16px;min-height:20px}
.pin-inf{font-size:13px;color:var(--g);text-align:center;margin-top:8px;display:none}

.card{background:var(--s);border:1px solid var(--b);border-radius:var(--r);padding:16px;margin-bottom:12px}
.slbl{font-size:11px;color:var(--t3);text-transform:uppercase;letter-spacing:.6px;margin-bottom:10px;font-weight:500}
.bname{font-size:22px;font-weight:600;letter-spacing:-.3px}
.bmeta{font-size:13px;color:var(--t2);margin-top:4px}

.btn{width:100%;padding:13px;border:none;border-radius:var(--rs);font-size:14px;font-weight:600;cursor:pointer;font-family:'Outfit',sans-serif;transition:all .15s;margin-top:8px}
.btn:disabled{opacity:.5;cursor:not-allowed}
.bg{background:var(--g);color:#000}.bg:active{background:var(--gd)}
.bo{background:transparent;border:1px solid var(--b);color:var(--t2)}.bo:active{background:var(--s2)}
.br{background:var(--rl);border:1px solid var(--rm);color:var(--rd)}
.ba{background:var(--wkl);border:1px solid var(--wkm);color:var(--wk)}
.brev{background:var(--goldl);border:1px solid var(--goldm);color:var(--gold)}
.bsm{padding:9px 14px;font-size:12px;width:auto;margin-top:0}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:8px}
.g3{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:8px}
.dbtn{padding:12px 8px;background:var(--bg3);border:1px solid var(--b);border-radius:var(--rs);font-size:13px;font-weight:600;color:var(--t2);cursor:pointer;text-align:center}
.dbtn:active{background:var(--wkl);color:var(--wk);border-color:var(--wkm)}

.tsel{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px}
.tb2{padding:16px 12px;border-radius:var(--rs);border:2px solid var(--b);background:var(--bg3);text-align:center;cursor:pointer;transition:all .15s}
.tb2.son{border-color:var(--on);background:var(--gl)}
.tb2.swk{border-color:var(--wk);background:var(--wkl)}
.ti{font-size:22px;margin-bottom:6px}
.tl{font-size:13px;font-weight:600}
.td{font-size:11px;color:var(--t3);margin-top:3px}

.ql{display:flex;flex-direction:column;gap:8px}
.qi{background:var(--s);border:1px solid var(--b);border-radius:var(--rs);padding:12px 14px;display:flex;align-items:center;gap:10px;cursor:pointer}
.qi:active{border-color:var(--brd)}
.qn{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;font-family:'JetBrains Mono',monospace;flex-shrink:0}
.qno{background:var(--gl);color:var(--on);border:1px solid var(--gm)}
.qnw{background:var(--wkl);color:var(--wk);border:1px solid var(--wkm)}
.qna{font-size:14px;font-weight:600}.qns{font-size:12px;color:var(--t3);margin-top:1px}

.bdg{display:inline-flex;align-items:center;padding:2px 7px;border-radius:20px;font-size:10px;font-weight:600;white-space:nowrap}
.bw{background:var(--bl);color:var(--bc)}.bn{background:var(--wkl);color:var(--wk)}
.bin{background:var(--gl);color:var(--on)}.bnew{background:var(--gl);color:var(--on)}
.bfr{background:var(--goldl);color:var(--gold)}.bgi{background:rgba(180,100,255,.12);color:#B464FF}
.bsk{background:var(--rl);color:var(--rd)}
.tag-on{background:var(--gl);color:var(--on);font-size:11px;padding:3px 8px;border-radius:20px;font-weight:600;display:inline-flex}
.tag-wk{background:var(--wkl);color:var(--wk);font-size:11px;padding:3px 8px;border-radius:20px;font-weight:600;display:inline-flex}

.sg{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px;margin-bottom:12px}
.st{background:var(--s);border:1px solid var(--b);border-radius:var(--rs);padding:13px}
.sv{font-size:26px;font-weight:600;font-family:'JetBrains Mono',monospace}.sl{font-size:12px;color:var(--t3);margin-top:2px}

.ban{border-radius:var(--rs);padding:12px 14px;margin-bottom:10px;font-size:13px;font-weight:500}
.ban-flag{background:var(--rl);border:1px solid var(--rm);color:#FF8090}
.ban-delay{background:var(--wkl);border:1px solid var(--wkm);color:var(--wk)}
.ban-next{background:var(--wkl);border:1px solid var(--wkm);color:var(--wk)}
.ban-now{background:var(--gl);border:1px solid var(--gm);color:var(--on)}
.ban-pause{background:var(--rl);border:1px solid var(--rm);color:#FF8090;text-align:center;padding:14px}
.ban-info{background:var(--bl);border:1px solid var(--bm);color:var(--bc)}
.ban-skip{background:var(--rl);border:1px solid var(--rm);color:#FF8090}

.pw{text-align:center;padding:28px 0 20px}
.pr{width:110px;height:110px;border-radius:50%;border:3px solid var(--gl);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;flex-direction:column;transition:all .4s}
.pnum{font-size:34px;font-weight:600;font-family:'JetBrains Mono',monospace;line-height:1}
.plbl{font-size:11px;color:var(--t3);margin-top:2px}
.ptit{font-size:17px;font-weight:600}.psub{font-size:13px;color:var(--t2);margin-top:5px;font-weight:300}
.tok-big{font-size:48px;font-weight:600;font-family:'JetBrains Mono',monospace;letter-spacing:-1px}
.tok-on{color:var(--on)}.tok-wk{color:var(--wk)}

.fl{font-size:12px;color:var(--t3);margin-bottom:6px;display:block;font-weight:500;text-transform:uppercase;letter-spacing:.4px}
.fi{width:100%;padding:12px 14px;background:var(--bg3);border:1px solid var(--b);border-radius:var(--rs);font-size:15px;color:var(--t);font-family:'Outfit',sans-serif;margin-bottom:12px}
.fi:focus{outline:none;border-color:var(--g)}
.fta{width:100%;padding:12px 14px;background:var(--bg3);border:1px solid var(--b);border-radius:var(--rs);font-size:14px;color:var(--t);font-family:'Outfit',sans-serif;margin-bottom:12px;min-height:80px;resize:none;line-height:1.5}
.fta:focus{outline:none;border-color:var(--g)}
.trow{display:flex;align-items:center;justify-content:space-between;padding:12px 14px;background:var(--bg3);border-radius:var(--rs);border:1px solid var(--b);margin-bottom:10px}
.tog{width:46px;height:26px;border-radius:13px;background:var(--s3);border:1px solid var(--b);position:relative;cursor:pointer;flex-shrink:0;transition:all .2s}
.tog.on{background:var(--g);border-color:var(--g)}
.tt{position:absolute;top:3px;left:3px;width:20px;height:20px;border-radius:50%;background:white;transition:left .2s;box-shadow:0 1px 3px rgba(0,0,0,.3)}
.tog.on .tt{left:23px}

.nb{background:var(--bl);border:1px solid var(--bm);border-radius:var(--rs);padding:14px;margin-top:10px}
.nl{font-size:11px;color:var(--bc);font-weight:600;text-transform:uppercase;letter-spacing:.4px;margin-bottom:6px}
.nt{font-size:14px;color:var(--t);line-height:1.6;font-weight:300}

.sdots{display:flex;gap:8px;justify-content:center;margin:12px 0 8px}
.sd{width:46px;height:46px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px;border:2px solid var(--b);background:var(--bg3);color:var(--t3);transition:all .3s}
.sd.on{background:var(--g);border-color:var(--g);color:#000;font-size:16px;box-shadow:0 0 12px var(--gm)}

.rc{background:linear-gradient(135deg,rgba(255,184,0,.15),rgba(255,184,0,.05));border:1px solid var(--goldm);border-radius:var(--r);padding:20px;text-align:center;margin-bottom:12px}
.gc-box{background:var(--bg2);border-radius:var(--rs);padding:12px 16px;margin:14px 0;border:1px solid var(--goldm)}
.gc{font-family:'JetBrains Mono',monospace;font-size:22px;font-weight:500;color:var(--gold);letter-spacing:4px}

.ci{background:var(--s);border:1px solid var(--b);border-radius:var(--rs);padding:14px;margin-bottom:10px;cursor:pointer}
.cn{font-size:14px;font-weight:600}.cl{font-size:11px;color:var(--g);margin-top:4px;font-family:'JetBrains Mono',monospace;word-break:break-all}
.cm{font-size:12px;color:var(--t3);margin-top:4px}

.cbtn{display:inline-flex;align-items:center;gap:6px;padding:10px 16px;background:var(--gl);border:1px solid var(--gm);border-radius:24px;font-size:13px;font-weight:600;color:var(--g);cursor:pointer;text-decoration:none;margin-top:8px}

.mo{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:999;display:none;align-items:flex-end;justify-content:center;backdrop-filter:blur(4px)}
.mo.open{display:flex}
.mb{background:var(--s);border-radius:var(--r) var(--r) 0 0;padding:24px 20px 36px;width:100%;max-width:500px;border-top:1px solid var(--b);max-height:90vh;overflow-y:auto}
.mh{font-size:16px;font-weight:600;margin-bottom:4px}
.ms{font-size:13px;color:var(--t3);margin-bottom:18px;font-weight:300}

.qrw{background:white;border-radius:var(--rs);padding:16px;display:flex;flex-direction:column;align-items:center;gap:10px;margin:12px 0}

.empty{padding:32px 0;text-align:center;font-size:13px;color:var(--t3);font-weight:300}
.divider{height:1px;background:var(--b);margin:14px 0}
.tw{position:fixed;bottom:32px;left:0;right:0;display:flex;justify-content:center;pointer-events:none;z-index:9998}
.toast{background:var(--s2);color:var(--t);padding:12px 22px;border-radius:24px;font-size:13px;font-weight:500;opacity:0;transform:translateY(10px);transition:all .25s;max-width:88%;text-align:center;line-height:1.4;border:1px solid var(--b);box-shadow:0 8px 32px rgba(0,0,0,.4)}
.toast.show{opacity:1;transform:translateY(0)}
.toast.tg{border-color:var(--gm);color:var(--on)}
.toast.ta{border-color:var(--goldm);color:var(--gold)}
.toast.tr{border-color:var(--rm);color:var(--rd)}
.section-sep{font-size:11px;color:var(--t3);text-transform:uppercase;letter-spacing:.8px;padding:16px 0 8px;border-top:1px solid var(--b);margin-top:8px}
</style>
</head>
<body>

<div id="loader">
  <div class="lo-ring">⚡</div>
  <div style="font-size:22px;font-weight:600;letter-spacing:-.5px">FlowSync</div>
  <div class="spin"></div>
  <div style="font-size:13px;color:var(--t3)" id="lo-msg">Loading...</div>
</div>

<div class="tw"><div class="toast" id="toast"></div></div>

<!-- PATIENT MODAL -->
<div class="mo" id="pm" onclick="closeMo('pm',event)">
  <div class="mb">
    <div class="mh" id="pm-name"></div>
    <div class="ms" id="pm-meta"></div>
    <div id="pm-call"></div>
    <div class="g2" style="margin-top:14px">
      <button class="btn br bsm" style="width:100%" onclick="noShow()">⏭ No-show / Skip</button>
      <button class="btn bo bsm" style="width:100%" onclick="closeMo('pm')">Close</button>
    </div>
  </div>
</div>

<!-- ADD PATIENT MODAL -->
<div class="mo" id="apm" onclick="closeMo('apm',event)">
  <div class="mb">
    <div class="mh">Add patient manually</div>
    <div class="ms">For patients without a mobile phone</div>
    <label class="fl">Patient name</label>
    <input class="fi" id="add-name" placeholder="e.g. Sunita Patel" style="margin-bottom:10px"/>
    <label class="fl">Type</label>
    <div class="tsel" style="margin-bottom:16px">
      <div id="add-on" class="tb2 son" onclick="setAddType('online')"><div class="ti">🌐</div><div class="tl" style="color:var(--on)">Online</div></div>
      <div id="add-wk" class="tb2" onclick="setAddType('walkin')"><div class="ti">🚶</div><div class="tl">Walk-in</div></div>
    </div>
    <button class="btn bg" onclick="addManual()">Add to queue</button>
    <button class="btn bo" onclick="closeMo('apm')">Cancel</button>
  </div>
</div>

<!-- PAUSE MODAL -->
<div class="mo" id="paum" onclick="closeMo('paum',event)">
  <div class="mb">
    <div class="mh">Pause queue</div>
    <div class="ms">Patients will see this message</div>
    <label class="fl">Message</label>
    <input class="fi" id="pau-msg" placeholder="Doctor on break — back at 2:30 PM"/>
    <button class="btn ba" onclick="doPause()">Pause queue</button>
    <button class="btn bo" onclick="closeMo('paum')">Cancel</button>
  </div>
</div>

<!-- SETTINGS MODAL -->
<div class="mo" id="setm" onclick="closeMo('setm',event)">
  <div class="mb">
    <div class="mh">Clinic settings</div>
    <div class="ms">Changes apply immediately to all portals</div>
    <label class="fl">Queue start time</label>
    <input class="fi" id="set-start" type="time"/>
    <label class="fl">Queue stop time</label>
    <input class="fi" id="set-stop" type="time"/>
    <label class="fl">Max patients per day (0 = unlimited)</label>
    <input class="fi" id="set-max" type="number" placeholder="0"/>
    <label class="fl">No-show grace period (minutes)</label>
    <input class="fi" id="set-grace" type="number" placeholder="5"/>
    <div class="divider"></div>
    <div class="trow" style="margin-bottom:12px">
      <div><div style="font-size:14px;font-weight:500">Loyalty stamps</div><div style="font-size:12px;color:var(--t3);margin-top:2px">4 stamps = free gift for friend/family</div></div>
      <div class="tog" id="set-loy-tog" onclick="toggleSetLoy()"><div class="tt"></div></div>
    </div>
    <div id="set-loy-row" style="display:none"><label class="fl">Reward description</label><input class="fi" id="set-reward" placeholder="e.g. Free consultation + medicines"/></div>
    <button class="btn bg" onclick="saveSettings()">Save settings</button>
    <button class="btn bo" onclick="closeMo('setm')">Cancel</button>
  </div>
</div>

<!-- BROADCAST MODAL -->
<div class="mo" id="bcm" onclick="closeMo('bcm',event)">
  <div class="mb">
    <div class="mh">📢 Broadcast message</div>
    <div class="ms">Appears on every patient's status screen instantly</div>
