function renderStaff(snap, p) {
  if (!snap || !snap.exists()) {
    if (p === "doc") { document.getElementById("doc-cur-name").textContent = "No patient in room"; document.getElementById("doc-cur-meta").textContent = "Queue empty"; document.getElementById("doc-q").innerHTML = '<div class="empty">Queue is empty</div>'; document.getElementById("doc-visitors").innerHTML = ""; }
    if (p === "rec") { document.getElementById("rec-tot").textContent = "0"; document.getElementById("rec-q").innerHTML = '<div class="empty">Queue is empty</div>'; document.getElementById("rec-visitors").innerHTML = ""; }
    return;
  }
  const q = getActive(snap);
  const visitors = getVisitors(snap);
  const cur = q.find(x => x.status === "with-doctor");
  const waiting = q.filter(x => x.status === "waiting" || x.status === "next" || x.status === "skipped");

  if (p === "doc") {
    const nf = document.getElementById("doc-note");
    const ct = nf.getAttribute("data-cur");
    document.getElementById("doc-cur-name").textContent = cur ? cur.name : "No patient in room";
    document.getElementById("doc-cur-meta").textContent = cur ? `Token #${cur.token} · ${cur.type === "walkin" ? "🚶 Walk-in" : "🌐 Online"} · ${cur.time}${cur.visits ? ` · Visit #${cur.visits}` : ""}${cur.isGift ? " · 🎁" : ""}` : "Tap Room ready to call next";
    document.getElementById("doc-cur-bdg").innerHTML = cur ? (lbadge(cur.visits, false) + (cur.isGift ? '<span class="bdg bgi" style="margin-left:6px">🎁 Gift</span>' : "")) : "";
    if (cur && String(cur.token) !== ct) { nf.value = cur.note || ""; nf.setAttribute("data-cur", String(cur.token)); }
    else if (!cur) { nf.value = ""; nf.setAttribute("data-cur", ""); }
  }
  if (p === "rec") {
    const onC = waiting.filter(x => x.type === "online").length + (cur?.type === "online" ? 1 : 0);
    const wkC = waiting.filter(x => x.type === "walkin").length + (cur?.type === "walkin" ? 1 : 0);
    document.getElementById("rec-on").textContent = onC;
    document.getElementById("rec-wk").textContent = wkC;
    document.getElementById("rec-tot").textContent = q.length;
    const nmp = q.filter(x => !x.hasPhone);
    document.getElementById("rec-flg").textContent = nmp.length;
    const fb = document.getElementById("rec-flag-ban");
    fb.style.display = nmp.length > 0 ? "block" : "none";
    if (nmp.length > 0) fb.textContent = `⚠️ ${nmp.length} patient${nmp.length > 1 ? "s need" : " needs"} in-person assist`;
  }

  const visEl = document.getElementById(`${p}-visitors`);
  if (visEl) {
    visEl.innerHTML = visitors.length === 0 ? "" : visitors.map(v => `<div class="qi" style="border-left:3px solid var(--bc)"><div class="qn" style="background:var(--bl);color:var(--bc);border-color:var(--bm)">👔</div><div style="flex:1"><div class="qna">${v.name}</div><div class="qns">${v.purpose || "Visitor"}</div></div><div onclick="dismissVisitor('${v._k}')" style="font-size:12px;color:var(--rd);cursor:pointer;padding:4px">✕</div></div>`).join("");
  }

  const exec = execOrder(waiting);
  const qEl = document.getElementById(`${p}-q`);
  if (exec.length === 0) { qEl.innerHTML = '<div class="empty">Queue is empty</div>'; return; }
  qEl.innerHTML = exec.map((x, i) => {
    const wk = x.type === "walkin";
    const lb = lbadge(x.visits, true);
    const gb = x.isGift ? '<span class="bdg bgi" style="font-size:10px;margin-left:3px">🎁</span>' : "";
    const np = !x.hasPhone ? '<span style="font-size:11px;color:var(--rd);margin-left:3px">📵</span>' : "";
    const sk = x.status === "skipped" ? '<span class="bdg bsk" style="font-size:10px;margin-left:3px">Skipped</span>' : "";
    const nx = i === 0 ? '<span class="bdg bn" style="font-size:10px;margin-left:3px">Next</span>' : "";
    const em = x.emergency ? '<span class="bdg" style="background:var(--rl);color:var(--rd);font-size:10px;margin-left:3px">🚨</span>' : "";
    const safeName = x.name.replace(/'/g, "\\'");
    return `<div class="qi ${x.emergency ? "qi-emerg" : ""}" onclick="openPM('${x._k}','${safeName}','${x.ph || ""}','${x.token}','${x.type || "online"}')">
      <div class="qn ${wk ? "qnw" : "qno"}">${wk ? "W" : ""}${x.token}</div>
      <div style="flex:1"><div class="qna">${x.name}${lb}${gb}${np}${sk}${nx}${em}</div><div class="qns">${wk ? "🚶 Walk-in" : "🌐 Online"} · ${x.time}</div></div>
    </div>`;
  }).join("");
}

// ==================== ROOM READY (LIVE SYNC WITH EMERGENCY MODE) ====================
async function roomReady() {
  const docBtn = document.getElementById("doc-ready");
  const recBtn = document.getElementById("rec-ready");
  if (docBtn) { docBtn.disabled = true; docBtn.textContent = "..."; }
  if (recBtn) { recBtn.disabled = true; recBtn.textContent = "..."; }
  try {
    const noteVal = document.getElementById("doc-note")?.value.trim() || "";
    await _db.ref(`queues/${CID}`).transaction(data => {
      if (!data) return data;
      const entries = Object.entries(data).map(([k, v]) => ({ ...v, key: k }));
      const curE = entries.find(e => e.status === "with-doctor");
      if (curE) {
        if (noteVal) data[curE.key].note = noteVal;
        data[curE.key].status = "done";
      }
      const waiting = entries.filter(e => (e.status === "waiting" || e.status === "next" || e.status === "skipped") && e.key !== curE?.key).sort((a, b) => Number(a.token) - Number(b.token));
      const ordered = execOrder(waiting);
      if (emergencyActive && ordered.length) {
        const emergencyEntry = ordered.find(e => e.emergency);
        if (emergencyEntry && data[emergencyEntry.key]) data[emergencyEntry.key].status = "with-doctor";
        else if (ordered[0] && data[ordered[0].key]) data[ordered[0].key].status = "with-doctor";
      } else if (ordered[0] && data[ordered[0].key]) {
        data[ordered[0].key].status = "with-doctor";
      }
      return data;
    });
    const nf = document.getElementById("doc-note");
    if (nf) { nf.value = ""; nf.setAttribute("data-cur", ""); }
  } catch (e) { toast("Error: " + e.message, "r"); }
  finally {
    if (docBtn) { docBtn.disabled = false; docBtn.textContent = "✓ Room ready"; }
    if (recBtn) { recBtn.disabled = false; recBtn.textContent = "✓ Room ready"; }
  }
}

