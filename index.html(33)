async function loadClinics() {
  document.getElementById("adm-list").innerHTML = '<div class="spin" style="margin:20px auto"></div>';
  try {
    const snap = await _db.ref("clinics").once("value");
    if (!snap.exists()) { document.getElementById("adm-list").innerHTML = '<div class="empty">No clinics yet</div>'; return; }
    const cs = []; snap.forEach(c => cs.push({ id: c.key, ...c.val() }));
    document.getElementById("adm-list").innerHTML = cs.map(c => {
      const link = `${location.origin}${location.pathname}?c=${c.id}`;
      return `<div class="ci" onclick="navigator.clipboard.writeText('${link}').then(()=>toast('Copied!','g'))">
        <div class="cn">${c.name}</div>
        <div class="cl">${link}</div>
        <div class="cm">Doc: ${c.doctorPin} · Rec: ${c.receptionPin}${c.maxPatients ? ` · Max: ${c.maxPatients}` : ""} · tap to copy</div>
      </div>`;
    }).join("");
  } catch (e) { document.getElementById("adm-list").innerHTML = '<div class="empty">Error loading</div>'; }
}

async function createClinic() {
  const name = document.getElementById("nc-name").value.trim();
  const dpin = document.getElementById("nc-dpin").value.trim();
  const rpin = document.getElementById("nc-rpin").value.trim();
  const rev = document.getElementById("nc-rev").value.trim();
  const start = document.getElementById("nc-start").value;
  const stop = document.getElementById("nc-stop").value;
  const max = parseInt(document.getElementById("nc-max").value) || 0;
  const grace = parseInt(document.getElementById("nc-grace").value) || 5;
  const reward = document.getElementById("nc-reward")?.value.trim() || "free consultation";
  if (!name || !dpin || !rpin) { toast("Fill clinic name and both PINs", "r"); return; }
  if (dpin.length !== 4 || rpin.length !== 4) { toast("PINs must be 4 digits", "r"); return; }
  const btn = document.getElementById("nc-btn");
  btn.disabled = true; btn.textContent = "Creating...";
  try {
    const id = name.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "") + "-" + Math.random().toString(36).slice(2, 4);
    await _db.ref(`clinics/${id}`).set({
      name, doctorPin: dpin, receptionPin: rpin, reviewLink: rev || "",
      startTime: start || "", stopTime: stop || "", maxPatients: max,
      gracePeriod: grace, loyaltyEnabled: ncLoy, rewardDesc: ncLoy ? reward : "",
      delay: 0, paused: false, createdAt: Date.now()
    });
    const link = `${location.origin}${location.pathname}?c=${id}`;
    lastLink = link;
    lastMsg = `Hi,\n\nYour FlowSync queue is ready! ⚡\n\nClinic link:\n${link}\n\nDoctor PIN: ${dpin}\nReceptionist PIN: ${rpin}\n${start ? `\nQueue hours: ${start} – ${stop || "close"}` : ""}\n${max ? `Max patients/day: ${max}` : ""}\n\nHow to use:\n• Print the QR code and place at front desk\n• Patients scan to check in from home or at clinic\n• Doctor & receptionist open same link and tap their portal\n• Patients see live queue before deciding to check in\n\nPowered by FlowSync`;
    document.getElementById("cr-name").textContent = name;
    document.getElementById("cr-link").textContent = link;
    document.getElementById("cr-msg").textContent = lastMsg;
    genQR(link, name);
    document.getElementById("nc-name").value = "";
    document.getElementById("nc-dpin").value = "";
    document.getElementById("nc-rpin").value = "";
    document.getElementById("nc-rev").value = "";
    document.getElementById("nc-start").value = "";
    document.getElementById("nc-stop").value = "";
    document.getElementById("nc-max").value = "0";
    document.getElementById("nc-grace").value = "5";
    if (document.getElementById("nc-reward")) document.getElementById("nc-reward").value = "";
    go("s-created");
  } catch (e) { toast("Error: " + e.message, "r"); }
  finally { btn.disabled = false; btn.textContent = "Generate clinic link →"; }
}

// ==================== QR CODE ====================
function genQR(url, name) {
  const canvas = document.getElementById("qr-canvas");
  canvas.width = 200; canvas.height = 200;
  const ctx = canvas.getContext("2d");
  const img = new Image(); img.crossOrigin = "anonymous";
  img.src = `https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=${encodeURIComponent(url)}&bgcolor=ffffff&color=000000&margin=10`;
  img.onload = () => ctx.drawImage(img, 0, 0, 200, 200);
  img.onerror = () => { ctx.fillStyle = "#fff"; ctx.fillRect(0, 0, 200, 200); ctx.fillStyle = "#333"; ctx.font = "12px sans-serif"; ctx.textAlign = "center"; ctx.fillText("QR: " + name, 100, 100); };
  document.getElementById("qr-lbl").textContent = `QR Code for ${name} · tap and hold to save`;
}

function copyLink() { navigator.clipboard.writeText(lastLink).then(() => toast("Copied!", "g")).catch(() => toast("Copy manually", "r")); }
function copyMsg() { navigator.clipboard.writeText(lastMsg).then(() => toast("Copied!", "g")).catch(() => toast("Copy failed", "r")); }

// ==================== LIVE PREVIEW (HOME) ====================
function setupLivePreview() {
  if (!CID) return;
  if (uLive) { uLive(); uLive = null; }
  uLive = _db.ref(`queues/${CID}`).on("value", snap => { _lpSnap = snap; renderLP(); });
  _db.ref(`clinics/${CID}`).on("value", snap => { if (snap && snap.exists()) cdata = snap.val(); renderLP(); });
}

let _lpSnap = null;
function renderLP() {
  const msg = document.getElementById("lp-msg");
  const nowEl = document.getElementById("lp-now");
  if (cdata?.paused) {
    msg.className = "lp-msg lp-paused";
    msg.textContent = "⏸ Queue paused — " + (cdata.pauseMsg || "Back soon");
    msg.style.display = "block"; nowEl.style.display = "none";
    document.getElementById("lp-on").textContent = "—";
    document.getElementById("lp-wk").textContent = "—";
    return;
  }
  if (!isOpen()) {
    const mins = minsUntilOpen();
    msg.className = "lp-msg " + (mins ? "lp-opens" : "lp-closed");
    msg.textContent = mins ? `⏰ Queue opens in ${mins} minute${mins !== 1 ? "s" : ""}` : "Queue is currently closed";
    msg.style.display = "block"; nowEl.style.display = "none";
    document.getElementById("lp-on").textContent = "0";
    document.getElementById("lp-wk").textContent = "0";
    return;
  }
  msg.style.display = "none";
  if (!_lpSnap || !_lpSnap.exists()) {
    document.getElementById("lp-on").textContent = "0";
    document.getElementById("lp-wk").textContent = "0";
    nowEl.style.display = "none"; return;
  }
  let onC = 0, wkC = 0, curTok = null;
  _lpSnap.forEach(c => {
    const p = c.val();
    if (p.status === "done" || p.type === "visitor") return;
    if (p.status === "with-doctor") { curTok = p.token; return; }
    if (p.status === "waiting" || p.status === "next" || p.status === "skipped") {
      p.type === "online" ? onC++ : wkC++;
    }
  });
  document.getElementById("lp-on").textContent = onC;
  document.getElementById("lp-wk").textContent = wkC;
  if (curTok) { nowEl.style.display = "flex"; document.getElementById("lp-tok").textContent = `#${curTok}`; }
  else { nowEl.style.display = "none"; }
}

function setupOwnerLivePreview() {
  _db.ref("queues").on("value", snap => {
    let onC = 0, wkC = 0, cur = null;
    if (snap && snap.exists()) {
      snap.forEach(cs => cs.forEach(c => {
        const p = c.val();
        if (p.status === "done" || p.type === "visitor") return;
        if (p.status === "with-doctor") cur = p.token;
        if (p.status === "waiting" || p.status === "next" || p.status === "skipped") {
          p.type === "online" ? onC++ : wkC++;
        }
      }));
    }
    document.getElementById("lp-on").textContent = onC;
    document.getElementById("lp-wk").textContent = wkC;
    const el = document.getElementById("lp-now");
    if (cur) { el.style.display = "flex"; document.getElementById("lp-tok").textContent = "#" + cur; }
    else { el.style.display = "none"; }
    document.getElementById("lp-msg").style.display = "none";
  });
}

// ==================== INIT ====================
async function init() {
  if (!CID) {
    document.getElementById("adm-card").style.display = "flex";
    document.getElementById("p-hint").textContent = "Owner dashboard";
    document.getElementById("home-tag").innerHTML = '<span class="ldot"></span>FlowSync Owner';
    document.getElementById("lp-wrap").style.display = "block";
    setupOwnerLivePreview();
    document.getElementById("loader").style.display = "none";
    document.getElementById("s-home").classList.add("active");
    return;
  }
  let tries = 0;
  while (tries < 3) {
    try {
      const snap = await _db.ref(`clinics/${CID}`).once("value");
      if (snap.exists()) {
        cdata = snap.val();
        document.getElementById("clinic-tag").textContent = cdata.name;
        document.getElementById("clinic-tag").style.display = "block";
        document.getElementById("home-tag").innerHTML = `<span class="ldot"></span>${cdata.name}`;
        document.getElementById("ci-sub").textContent = cdata.name;
        document.getElementById("p-hint").textContent = cdata.name;
        if (cdata.gifts) document.getElementById("gift-row").style.display = "block";
        document.getElementById("lp-wrap").style.display = "block";
        setupLivePreview();
        document.getElementById("loader").style.display = "none";
        document.getElementById("s-home").classList.add("active");
        const saved = localStorage.getItem(`myToken_${CID}`);
        if (saved) {
          const snapQ = await _db.ref(`queues/${CID}`).once("value");
          if (snapQ.exists()) {
            let found = null;
            snapQ.forEach(c => { const p = c.val(); if (Number(p.token) === Number(saved)) found = p; });
            if (found && found.status !== "done") {
              myTok = found.token; myPh = found.ph || null; myType = found.type || "online";
              myVisits = found.visits || 1;
              document.getElementById("st-name").textContent = found.name;
              document.getElementById("st-tok").textContent = `#${found.token}`;
              document.getElementById("st-tok").className = `tok-big ${found.type === "walkin" ? "tok-wk" : "tok-on"}`;
              document.getElementById("st-tok-type").innerHTML = `<span class="${found.type === "walkin" ? "tag-wk" : "tag-on"}">${found.type === "walkin" ? "🚶 Walk-in" : "🌐 Online"}</span>`;
              go("s-status");
            } else { localStorage.removeItem(`myToken_${CID}`); }
          }
        }
        return;
      } else {
        document.getElementById("lo-msg").textContent = "Clinic not found. Check your link.";
        setTimeout(() => { document.getElementById("loader").style.display = "none"; document.getElementById("s-home").classList.add("active"); }, 3000);
        return;
      }
    } catch (e) { tries++; document.getElementById("lo-msg").textContent = `Connecting... (${tries}/3)`; await sleep(2000); }
  }
  document.getElementById("lo-msg").textContent = "Connection failed. Check internet.";
  setTimeout(() => { document.getElementById("loader").style.display = "none"; document.getElementById("s-home").classList.add("active"); }, 5000);
}

